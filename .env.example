APP_NAME=DailyStoryBook API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dailystorybook
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
