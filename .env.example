APP_NAME=DailyStoryBook API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
LOG_JSON=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dailystorybook
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
APP_PUBLIC_BASE_URL=http://127.0.0.1:8000
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=media
LOCAL_MEDIA_URL_PREFIX=/media
UPLOAD_MAX_IMAGE_SIZE_BYTES=5242880
UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
AWS_ACCESS_KEY_ID=dummy-access-key
AWS_SECRET_ACCESS_KEY=dummy-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_ENDPOINT_URL=
AWS_S3_PUBLIC_BASE_URL=
AI_BACKEND_BASE_URL=http://localhost:8001/api/v1
AI_BACKEND_TIMEOUT_SECONDS=1000
AI_BACKEND_MAX_RETRIES=2
AI_BACKEND_RETRY_BACKOFF_SECONDS=0.5
ADMIN_PANEL_PATH=/admin-panel
ADMIN_USERNAME=adminstorybook
ADMIN_PASSWORD=iamadmin

